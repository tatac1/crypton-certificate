packages:
  crypton-x509
  crypton-x509-store
  crypton-x509-system
  crypton-x509-validation
  crypton-x509-util
  tcg-platform-cert
  tcg-platform-cert-validation
  tcg-platform-cert-util
  platform-hardware-info
  x509-ac-validation

-- Allow newer versions for compatibility
allow-newer:
  *:base,
  *:bytestring,
  *:crypton,
  *:crypton-x509,
  *:time

-- Constraints to resolve version conflicts
constraints:
  base >= 4.16,
  bytestring >= 0.10
